# ============================================
# CloudShop SaaS - Environment Variables
# ============================================

# ─── Database (saas_core) ───────────────────
CORE_DB_HOST=localhost
CORE_DB_NAME=saas_core
CORE_DB_USER=root
CORE_DB_PASS=your_password
DB_PORT=3306

# Set to 'true' if using shared hosting (can't create new DB users)
SHARED_HOSTING=false

# ─── Authentication ─────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# Admin panel password
ADMIN_PASSWORD=admin2026
ADMIN_API_KEY=cloudshop-admin-2026

# ─── MercadoPago (Primary Payment Provider) ──
# Get credentials at: https://www.mercadopago.com/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx
MP_PLAN_AMOUNT=20
MP_BACK_URL=https://your-domain.com/panel
MP_WEBHOOK_SECRET=your-webhook-secret

# ─── Stripe (Alternative Payment Provider) ──
# Get credentials at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_CURRENCY=usd
SUBSCRIPTION_PRICE=2000

# ─── URLs ────────────────────────────────────
FRONTEND_URL=https://cloudshop.com
API_URL=https://api.cloudshop.com

# ─── Email (Optional - SendGrid) ────────────
# Get credentials at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
EMAIL_FROM=noreply@cloudshop.com

# ─── Trial & Subscription Settings ──────────
TRIAL_DAYS=7
GRACE_PERIOD_DAYS=3

# ─── CORS ────────────────────────────────────
# Comma-separated list of allowed origins (or * for all)
CORS_ORIGINS=https://cloudshop.com,https://www.cloudshop.com

# ─── Server ──────────────────────────────────
PORT=3000
NODE_ENV=development
